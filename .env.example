# Optional shared configuration for busco_to_merian.sh

# Base directory for local data.
DATA_ROOT=/path/to/project_data

# Override individual locations if needed.
BUSCO_DIR=/path/to/project_data/busco
OUTPUT_DIR=/path/to/project_data/merians

# Input files in the working directory.
TOLID_FILE=tolids
ACCESSION_FILE=tolids_accessions.tsv

# Optional custom reference table path.
MERIAN_REF=Merian_elements_full_table.tsv
